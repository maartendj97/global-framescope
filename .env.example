# EVENTS_SOURCE=mock|live (defaults to "live" when unset)
# "mock" forces the hardcoded fixtures in src/data/events.ts, useful for
# local dev without hitting the live GNews API, or as an instant rollback
# in production if GNews ever misbehaves.
EVENTS_SOURCE=live

# Required for live events. Free account: https://gnews.io
# Without this set, getEvents() automatically falls back to mock data.
GNEWS_API_KEY=

# The deployed site origin, used so relative Open Graph image paths (the
# category illustrations) resolve to absolute URLs when a page is shared.
# Falls back to http://localhost:3000 if unset, which is fine for local dev.
NEXT_PUBLIC_SITE_URL=

# Shared cache (Upstash Redis). On Vercel these are injected automatically
# by the Upstash integration; locally they're optional — without them the
# app falls back to per-process in-memory caching, which is fine for dev.
KV_REST_API_URL=
KV_REST_API_TOKEN=
