# Full URL of the main app's protected metrics endpoint, e.g.
# https://global-framescope.vercel.app/api/admin/metrics
METRICS_API_URL=

# Must match METRICS_API_TOKEN set on the main app (global-framescope) —
# this is the bearer token sent when fetching METRICS_API_URL.
METRICS_API_TOKEN=

# Password for this dashboard's own login screen. Pick a long random
# value; there's no username, just this one shared password.
DASHBOARD_PASSWORD=
