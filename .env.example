# EVENTS_SOURCE=mock|live|currents (defaults to "live" when unset)
# "live"     GNews primary, Currents as backup when GNews is empty
# "mock"     hardcoded fixtures in src/data/events.ts (dev / instant rollback)
# "currents" force Currents only, to verify that source in isolation
EVENTS_SOURCE=live

# Required for live events. Free account: https://gnews.io
# Without this set, getEvents() automatically falls back to mock data.
GNEWS_API_KEY=

# Optional backup news source. Free account (1,000 req/day, no card):
# https://currentsapi.services — used only when GNews returns nothing.
# Without this set, the Currents backup stays dormant.
CURRENTS_API_KEY=

# The deployed site origin, used for Open Graph URLs, robots.txt, and
# sitemap.xml (see src/lib/siteUrl.ts). Optional on Vercel: when unset,
# the code falls back to the auto-injected VERCEL_PROJECT_PRODUCTION_URL,
# then to http://localhost:3000 for local dev. Only set this explicitly
# when the site runs on a custom domain.
NEXT_PUBLIC_SITE_URL=

# Enables the per-country AI framing summaries on the Countries tab
# (claude-haiku-4-5, ~$0.002 per summary, cached 24h in Redis). Create a
# key at https://platform.claude.com — without it the summary section is
# simply hidden and the sources view works as before.
ANTHROPIC_API_KEY=

# Hard daily ceiling on AI summary generations across all instances
# (spend guard for future traffic). Defaults to 300 (~$0.60/day worst
# case) when unset.
ANTHROPIC_DAILY_SUMMARY_CAP=

# Shared cache (Upstash Redis). On Vercel these are injected automatically
# by the Upstash integration; locally they're optional — without them the
# app falls back to per-process in-memory caching, which is fine for dev.
KV_REST_API_URL=
KV_REST_API_TOKEN=
